# Copy to .env and fill in. .env is gitignored.

# --- Band platform (band.ai) ---
# Defaults below match band-sdk 1.0.0; override only if the dashboard says otherwise.
BAND_WS_URL="wss://app.band.ai/api/v1/socket/websocket"
BAND_REST_URL="https://app.band.ai"
# Owner handle used by band-trigger as @<owner>/<agent-name>
BAND_OWNER_HANDLE="@your-owner-handle"

# --- AI/ML API (partner prize — @RiskScorer reasoning runs through this) ---
AIML_API_KEY=""
AIML_BASE_URL="https://api.aimlapi.com/v1"
# Known-good reasoning model id (vendor/model). Confirm at kickoff.
AIML_MODEL="openai/gpt-4.1"

# CrewAI (@RiskScorer) routes through litellm; point it at AI/ML API:
# these are read by the CrewAI adapter / litellm at runtime.
OPENAI_BASE_URL="https://api.aimlapi.com/v1"
OPENAI_API_KEY="${AIML_API_KEY}"

# --- Claude SDK adapter (@Intake / fallback agents) ---
ANTHROPIC_API_KEY=""

# --- Codex adapter (@Counsel) ---
# CODEX_* / OPENAI_API_KEY as required by the Codex adapter config.
